# Normalize text files in the repository and use LF by default.
* text=auto eol=lf

# Keep Windows-native scripts compatible with Windows tooling.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Never alter line endings in binary artifacts.
*.gz binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
