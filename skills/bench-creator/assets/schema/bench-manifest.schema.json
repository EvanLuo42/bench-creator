{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ai-work-bench:schema:manifest:v1",
  "title": "AI Work Bench Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "name",
    "description",
    "created_at",
    "updated_at",
    "capture_policy",
    "runner"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": "ai-work-bench/v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "capture_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "minimum_signals",
        "max_cases_per_task",
        "require_redaction"
      ],
      "properties": {
        "mode": {
          "enum": [
            "auto",
            "suggest",
            "off"
          ]
        },
        "minimum_signals": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9
        },
        "max_cases_per_task": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "require_redaction": {
          "type": "boolean"
        },
        "workspace_mode": {
          "enum": [
            "off",
            "repo-ref",
            "snapshot"
          ]
        },
        "max_snapshot_mb": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10240
        }
      }
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol",
        "timeout_seconds"
      ],
      "properties": {
        "protocol": {
          "const": "ai-work-bench/candidate-v1"
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "visibility": {
          "enum": [
            "private",
            "team"
          ]
        },
        "allow_source_export": {
          "type": "boolean"
        }
      }
    }
  }
}
